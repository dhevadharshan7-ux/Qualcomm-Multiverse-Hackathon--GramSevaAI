# Copy to .env and adjust as needed. python-dotenv loads this automatically
# if you `from dotenv import load_dotenv; load_dotenv()` — or export these
# in your shell before running uvicorn.
#
# INTRANET DEPLOYMENT: if Postgres and/or the three local models run on a
# different machine on the panchayat office LAN than this orchestrator, swap
# every `localhost` below for that machine's LAN IP (e.g. 192.168.1.50).
# All three model backends and Postgres must be reachable from wherever
# `uvicorn orchestrator.main:app` actually runs.

DATABASE_URL=postgresql+psycopg://gramseva:gramseva@localhost:5432/gramseva

# --- Model 1: Gemma4 (intent classification + field extraction) ---------
# mock = offline, keyword-based classifier (default, no model needed).
# ollama = real Gemma4 via a local Ollama server.
LLM_BACKEND=mock
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:4b

# --- Model 2: Whisper (speech-to-text for voice intake) ------------------
# stub = raises a clear error on any voice request (default, no model needed).
# whisper = calls WHISPER_STT_URL. NOTE: this targets the OpenAI-compatible
# /v1/audio/transcriptions multipart shape (whisper.cpp server /
# faster-whisper-server / common Ollama-fronting shims) — Ollama's own
# /api/generate does not natively do audio. Confirm this path matches your
# actual local Whisper setup and adjust if not.
STT_BACKEND=stub
WHISPER_STT_URL=http://localhost:11434/v1/audio/transcriptions
WHISPER_MODEL=whisper-large-v3-turbo

# --- Model 3: document/ID vision-OCR (Aadhaar/PAN/DL photo extraction) ---
# stub = filename-based document-type guess only, no field extraction (default).
# ollama-vlm = a vision-language model served Ollama-style (e.g. a quantized
# Qwen2-VL pulled into the same Ollama instance serving Gemma4).
VISION_BACKEND=stub
VISION_MODEL=qwen2-vl:2b

# Below this local-classification confidence, requests are routed through
# the (stubbed) cloud_escalate() path instead of being trusted as-is.
CONFIDENCE_THRESHOLD=0.6

# --- Cross-service (Node backend bridge) ---------------------------------
# The Node/Express backend's raiseComplaint/listComplaints bridge calls back
# into this orchestrator — see Gram_Seva_Ai/backend/.env's
# PYTHON_ORCHESTRATOR_URL, which must point at wherever this app runs
# (localhost:8000 if co-located, else this machine's LAN IP:8000).
