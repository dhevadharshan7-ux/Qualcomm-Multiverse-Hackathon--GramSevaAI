# ═══════════════════════════════════════════════════════════════
#  Gram Seva AI — Environment Configuration (EXAMPLE)
#  Copy this file to .env and fill in your own values.
#  NEVER commit .env (with real secrets) to version control.
# ═══════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/Gram_Seva_Ai"

# ─── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=INFO
CORS_ORIGIN=http://localhost:5173

# ─── Auth ──────────────────────────────────────────────────────
# REQUIRED in any real deployment. If left unset, the server falls back to a
# hardcoded dev secret (logged loudly at boot) and every officer JWT can be
# forged by anyone who has read the source code. Generate a strong random
# value, e.g.: `openssl rand -base64 48`
JWT_SECRET=
JWT_EXPIRES_IN=7d
OFFICER_JWT_EXPIRES_IN=12h

# ─── Claude / Anthropic ────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Google Vertex AI (Alternative Claude provider) ────────────
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1

# ─── Gemini ────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com
GEMINI_API_KEY=

# ─── Sarvam AI (Indian language speech/translation) ────────────
# Get your key at: https://sarvam.ai
SARVAM_API_KEY=
SARVAM_BASE_URL=https://api.sarvam.ai

# ─── WhatsApp Business API ─────────────────────────────────────
# From Meta Developer Console
WHATSAPP_VERIFY_TOKEN=gram-seva-whatsapp-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ─── Python Orchestrator / Grievance Platform ──────────────────
# Base URL of the teammate's FastAPI service that owns grievances
# (POST/GET /grievances). Defaults to http://localhost:8000 if unset.
PYTHON_ORCHESTRATOR_URL=http://localhost:8000

# ─── Firebase Admin (Firestore bridge) ─────────────────────────
# Optional. If any of these three are left unset, firebaseAdmin.js safely
# no-ops (db stays null) and the Firebase sync worker / live-sync job will
# log that the bridge is inactive instead of starting.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines (as exported by the
# Firebase console's service-account JSON); this code un-escapes them.
FIREBASE_PRIVATE_KEY=
