# Copy to .env.local and fill in.

# Python orchestrator (voice/grievance/ID-request core flows). Point at the
# compute hub's LAN IP if the website isn't running on the same machine.
VITE_ORCHESTRATOR_URL=http://localhost:8000

# Firebase (per react_firebase_integration.md) — powers cross-device "My
# Grievances" live status via the Node backend's gram_seva_live mirror.
# Get these from Firebase Console > Project Settings > General > Your apps.
# Left blank, the app still works for the core voice/grievance/ID-request
# flows — only the live-status list degrades to a "not connected" message.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
